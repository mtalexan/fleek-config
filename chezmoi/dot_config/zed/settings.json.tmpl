// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
{{- if .zed.gitlab_mcp }}
  "context_servers": {
    "mcp-server-gitlab": {
      "enabled": true,
      "remote": false,
      "settings": {
        "gitlab_personal_access_token": "{{ includeTemplate "age-decrypt-string" .zed.secrets.gitlab_pat }}",
        "gitlab_api_url": "{{ .zed.gitlab_api_url }}"
      }
    }
  },
{{- end }}
  "cli_default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "cursor_blink": false,
  "preview_tabs": {
    "enable_keep_preview_on_code_navigation": true,
    "enable_preview_file_from_code_navigation": true,
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_preview_from_file_finder": false
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_menus": false,
    "show_sign_in": false
  },
  "status_bar": {
    "show_active_file": true,
    "active_encoding_button": "enabled"
  },
  "search": {
    "center_on_match": true,
    "include_ignored": true
  },
  "current_line_highlight": "all",
  "unnecessary_code_fade": 0.5,
  "minimum_contrast_for_highlights": 80.0,
{{- if .zed.copilot }}
  "edit_predictions": {
    "provider": "copilot"
  },
{{- end }}
  "agent": {
    "default_profile": "write",
    "dock": "right",
    "tool_permissions": {
      "tools": {
        "copy_path": {
          "default": "allow"
        }
      },
      "default": "allow"
    },
{{- if .zed.copilot }}
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-opus-4.6"
    }
{{- end }}
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Colored Zed Icons Theme Dark",
    "dark": "Colored Zed Icons Theme Dark"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  // Control this with nix home-manager instead
  "auto_update": false,
  "ui_font_size": 14,
  "buffer_font_size": 13,
  "buffer_line_height": "standard",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Vibrant Abyss Borders"
  },
  "theme_overrides": {
    "Nebula Nova": {
      // Nebula Nova theme is here: https://github.com/foxoman/nebula-pulse-zed-theme/blob/main/themes/nebula-nova.json

      // as bright as possible. When jumping between search matches, the pane is dimmed and the highlighted line number is the only way to tell where we are
      "editor.active_line_number": "#00FF00FF",
      "players": [
        {
          // The current highlight selection.
          // default is: "#75BEFF3D"
          "selection": "#75BEFF88"
        }
      ]
    }
  },
  "pane_split_direction_horizontal": "down",
  // The direction that you want to split panes horizontally. Defaults to "left"
  "pane_split_direction_vertical": "right",
  "wrap_guides": [80],
  "show_whitespaces": "boundary",
  // Minimap related settings
  "minimap": {
    // always show the minimap, even if the content fits on one screen and the scrollbar isn't needed.
    "show": "always"
  },
  "gutter": {
    // Whether to show fold buttons in the gutter.
    "folds": false
  },
  "indent_guides": {
    "active_line_width": 2,
    "coloring": "indent_aware"
  },
  "seed_search_query_from_cursor": "selection",
  "use_smartcase_search": true,
  "inlay_hints": {
    // e.g. parameters, types, etc
    "enabled": true,
    // use the completion background for inlay hints?
    "show_background": false
  },
  "project_panel": {
    "dock": "left",
    "entry_spacing": "standard"
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false
  },
  // Whether the screen sharing icon is shown in the os status bar.
  "show_call_status_icon": false,
  "message_editor": {
    // Whether to automatically replace emoji shortcodes with emoji characters.
    // For example: typing `:wave:` gets replaced with `👋`.
    "auto_replace_emoji_shortcode": false
  },
  "autosave": { "after_delay": { "milliseconds": 500 } },
  "tabs": {
    // Show git status colors in the editor tabs.
    "git_status": true,
    "file_icons": true,
    "show_diagnostics": "errors"
  },
  "file_finder": {
    "modal_max_width": "large"
  },
  "remove_trailing_whitespace_on_save": false,
  "ensure_final_newline_on_save": false,
  "format_on_save": "off",
  // softwrap now makes the wrapped lines appear indented, which is impossible to differentiate from hard wrap
  // unless whitespace is shown. So disable it by default.
  "soft_wrap": "none",
  "diagnostics": {
    "inline": {
      "enabled": true,
      // make it kind of line up on the right side
      "min_column": 80,
      //only show inline errors, others are shown other ways
      "max_severity": "error"
    }
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
      // make sure it has a minimum offset so it doesn't get in the way
      "min_column": 80
    }
  },
  "journal": {
    "hour_format": "hour24"
  },
  "terminal": {
    "shell": {
      "program": "zsh"
    },
    "line_height": "standard",
    "detect_venv": "off",
    // max allowed is 100_000
    "max_scroll_history_lines": 100000
  },

  // Use semantic token parsing from the LSP if it's available, combined with the tree-sitter regex-based token highlighting.
  // Not sure why this is disabled by default, set it to the option that actually makes sense.
  "semantic_tokens": "combined",
  
  "languages": {
    "Markdown": {
      // for some reason this is getting ignored in favor of the global override
      "soft_wrap": "editor_width"
    }
  },

  "git_hosting_providers": [
    {
      "provider": "gitlab",
      "name": "SCM-02",
      "base_url": "https://scm-02.karlstorz.com"
    }
  ],

  // The following is the list of installed extensions that we want installed by
  // all systems that use this same file. These have to be manually populated here by
  // running: `jq '.extensions | with_entries(.key=.value.manifest.id, .value=true)' ~/.local/share/zed/extensions/index.json`
  // and then copy-pasting the results into the auto_install_extensions here.
  "auto_install_extensions": {
    "ansible": true,
    "asciidoc": true,
    "awk": true,
    "basher": true,
    "bitbake": true,
    "blackfox": true,
    "blueprint": true,
    "caddyfile": true,
    "cargo-appraiser": true,
    "cargo-tom": true,
    "catppuccin": true,
    "codebook": true,
    "codeowners": true,
    "color-highlight": true,
    "colored-zed-icons-theme": true,
    "colorizer": true,
    "comment": true,
    "crates-lsp": true,
    "csv": true,
    "dark-pop-ui": true,
    "desktop": true,
    "devicetree": true,
    "docker-compose": true,
    "dockerfile": true,
    "editorconfig": true,
    "elisp": true,
    "env": true,
    "fleet-themes": true,
    "git-firefly": true,
    "github-actions": true,
    "go-snippets": true,
    "golangci-lint": true,
    "gosum": true,
    "gotmpl": true,
    "graphviz": true,
    "groovy": true,
    "haku-dark-theme": true,
    "haskell": true,
    "helm": true,
    "html": true,
    "html-jinja": true,
    "ini": true,
    "java": true,
    "jinja2": true,
    "jq": true,
    "json5": true,
    "jsonnet": true,
    "just": true,
    "kconfig": true,
    "latex": true,
    "linkerscript": true,
    "log": true,
    "logstash": true,
    "lua": true,
    "make": true,
    "markdown-oxide": true,
    "mermaid": true,
    "meson": true,
    "modest-dark": true,
    "mpls": true,
    "nebula-pulse": true,
    "neocmake": true,
    "nginx": true,
    "nickel": true,
    "ninja": true,
    "nix": true,
    "one-dark-darkened": true,
    "one-dark-pro": true,
    "one-dark-pro-max": true,
    "org": true,
    "pathy": true,
    "perl": true,
    "php": true,
    "plantuml": true,
    "powershell": true,
    "proto": true,
    "pylsp": true,
    "pytest-language-server": true,
    "python-refactoring": true,
    "python-requirements": true,
    "python-snippets": true,
    "qml": true,
    "quadlet": true,
    "r": true,
    "racket": true,
    "rpmspec": true,
    "ruby": true,
    "rust-snippets": true,
    "scala": true,
    "scheme": true,
    "ssh-config": true,
    "strace": true,
    "structured-text": true,
    "terraform": true,
    "tmux": true,
    "tombi": true,
    "toml": true,
    "tree-sitter-query": true,
    "typos": true,
    "visual-assist-dark": true,
    "vitesse-theme-refined": true,
    "xml": true,
    "xonsh": true,
    "zedokai": true,
    "zig": true
  }
}
